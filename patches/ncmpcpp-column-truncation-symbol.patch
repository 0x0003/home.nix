diff --git a/src/utility/wide_string.cpp b/src/utility/wide_string.cpp
index 70edc93..5ef6f87 100644
--- a/src/utility/wide_string.cpp
+++ b/src/utility/wide_string.cpp
@@ -35,17 +35,30 @@ size_t wideLength(const std::wstring &ws)
 	return result;
 }
 
-void wideCut(std::wstring &ws, size_t max_length)
+void wideCut(std::wstring &ws, size_t max_length, const std::wstring *truncation_symbol)
 {
+	size_t ellipsis_len = 0;
+	if (truncation_symbol)
+	{
+		ellipsis_len = wideLength(*truncation_symbol);
+		if (max_length < ellipsis_len)
+		{
+			ws.clear();
+			return;
+		}
+	}
+	size_t target = max_length - ellipsis_len;
 	size_t i = 0;
-	int remained_len = max_length;
+	int remained_len = target;
 	for (; i < ws.length(); ++i)
 	{
 		remained_len -= std::max(wcwidth(ws[i]), 1);
 		if (remained_len < 0)
 		{
 			ws.resize(i);
-			break;
+			if (truncation_symbol)
+				ws += *truncation_symbol;
+			return;
 		}
 	}
 }
