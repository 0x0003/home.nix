+std::string Song::getRating(unsigned idx) const
+{
+	if (idx > 0)
+		return "";
+	const char *uri_ptr = c_uri();
+	if (!uri_ptr || !*uri_ptr)
+		return " ";
+	std::string uri(uri_ptr);
+	auto &cache = ratingCache();
+	auto it = cache.find(uri);
+	if (it != cache.end())
+		return it->second;
+	std::string val;
+	try {
+		val = Mpd.GetSticker(uri, "rating");
+	} catch (...) {
+		cache[uri] = " ";
+		return " ";
+	}
+	if (val.empty())
+	{
+		cache[uri] = " ";
+		return " ";
+	}
+	int r = 0;
+	try {
+		r = boost::lexical_cast<int>(val);
+	} catch (...) {
+		cache[uri] = " ";
+		return " ";
+	}
+	if (r <= 0)
+	{
+		cache[uri] = " ";
+		return " ";
+	}
+	r = std::min(r, 10);
+	static const std::string kFull = "\xe2\x98\x85";  // U+2605 black star
+	static const std::string kHalf = "\xe2\xaf\xaa";  // U+2BEA star with left half black
+	static const std::string kEmpty = "\xe2\x98\x86"; // U+2606 white star
+	int full = r / 2;
+	int half = r % 2;
+	std::string result;
+	for (int i = 0; i < full; ++i)
+		result += kFull;
+	if (half)
+		result += kHalf;
+	for (int i = full + half; i < 5; ++i)
+		result += kEmpty;
+	cache[uri] = result;
+	return result;
+}
