+static void doRate(HasSongs *hs, int value)
+{
+	auto songs = hs->getSelectedSongs();
+	for (const auto &s : songs)
+	{
+		const char *uri = s.c_uri();
+		if (!uri || !*uri)
+			continue;
+		try
+		{
+			if (value >= 0)
+				Mpd.SetSticker(uri, "rating", boost::lexical_cast<std::string>(value));
+			else
+				Mpd.DeleteSticker(uri, "rating");
+		}
+		catch (...) { }
+	}
+	MPD::clearRatingCache();
+	myScreen->refreshWindow();
+}
+
+bool RateTen::canBeRun()
+{
+	m_hs = dynamic_cast<HasSongs *>(myScreen);
+	return m_hs != nullptr && m_hs->itemAvailable();
+}
+
+void RateTen::run()
+{
+	doRate(m_hs, 10);
+}
+
+bool RateRemove::canBeRun()
+{
+	m_hs = dynamic_cast<HasSongs *>(myScreen);
+	return m_hs != nullptr && m_hs->itemAvailable();
+}
+
+void RateRemove::run()
+{
+	doRate(m_hs, -1);
+}
+
