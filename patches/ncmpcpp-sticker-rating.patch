+std::string Connection::GetSticker(const std::string &uri, const std::string &name)
+{
+	prechecksNoCommandsList();
+	mpd_send_command(m_connection.get(), "sticker", "get", "song", uri.c_str(), name.c_str(), NULL);
+	std::string result;
+	if (mpd_pair *pair = mpd_recv_pair_named(m_connection.get(), "sticker"))
+	{
+		std::string s(pair->value);
+		size_t eq = s.find('=');
+		if (eq != std::string::npos)
+			result = s.substr(eq + 1);
+		mpd_return_pair(m_connection.get(), pair);
+	}
+	mpd_response_finish(m_connection.get());
+	auto err = mpd_connection_get_error(m_connection.get());
+	if (err == MPD_ERROR_SERVER
+	    && (mpd_connection_get_server_error(m_connection.get()) == MPD_SERVER_ERROR_NO_EXIST
+	        || mpd_connection_get_server_error(m_connection.get()) == MPD_SERVER_ERROR_UNKNOWN_CMD))
+		mpd_connection_clear_error(m_connection.get());
+	else if (err != MPD_ERROR_SUCCESS)
+		checkErrors();
+	return result;
+}
